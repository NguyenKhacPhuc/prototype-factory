{
  "buildCommand": "bun build.ts",
  "installCommand": "bun install",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/prototypes/(.*)", "destination": "/prototypes/$1" },
    { "source": "/:path((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
